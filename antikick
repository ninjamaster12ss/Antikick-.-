-- Update whitelist display
local function updateWlList()
    local names = {}
    for name in pairs(whitelist) do
        table.insert(names, "• " .. name)
    end
    if #names == 0 then
        wlList.Text = "No players whitelisted"
    else
        wlList.Text = table.concat(names, "\n")
    end
end

-- Notification function
local function notify(msg)
    local screenGui2 = Instance.new("ScreenGui")
    screenGui2.ResetOnSpawn = false
    screenGui2.Parent = playerGui

    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(0, 250, 0, 40)
    notifFrame.Position = UDim2.new(0.5, -125, 0, 20)
    notifFrame.BackgroundColor3 = Color3.fromRGB(255, 245, 180)
    notifFrame.BackgroundTransparency = 0.87
    notifFrame.BorderSizePixel = 0
    notifFrame.Parent = screenGui2

    local notifLabel = Instance.new("TextLabel")
    notifLabel.Size = UDim2.new(1, 0, 1, 0)
    notifLabel.BackgroundTransparency = 1
    notifLabel.Text = msg
    notifLabel.TextColor3 = Color3.fromRGB(255, 232, 138)
    notifLabel.TextSize = 12
    notifLabel.Font = Enum.Font.Gotham
    notifLabel.Parent = notifFrame

    task.delay(4, function()
        for i = 1, 10 do
            notifFrame.BackgroundTransparency = 0.87 + (0.13 * i / 10)
            notifLabel.TextTransparency = i / 10
            task.wait(0.1)
        end
        screenGui2:Destroy()
    end)
end

-- Send chat function (legacy first, 0.05 delay)
local function sendChat(message)
    if not message or message == "" then return end

    task.wait(0.05)

    local ok1, err1 = pcall(function()
        local chatEvent = ReplicatedStorage:WaitForChild("DefaultChatSystemChatEvents", 3)
            :WaitForChild("SayMessageRequest", 3)
        chatEvent:FireServer(message, nil)
    end)

    if not ok1 then
        warn("Legacy chat failed: " .. tostring(err1))
        local ok2, err2 = pcall(function()
            local TextChatService = game:GetService("TextChatService")
            local channel = TextChatService.TextChannels:WaitForChild("RBXGeneral", 3)
            channel:SendAsync(message)
        end)
        if not ok2 then
            warn("TextChatService fallback also failed: " .. tostring(err2))
        end
    end
end

-- Autocomplete logic
local currentSuggestion = ""

wlInput:GetPropertyChangedSignal("Text"):Connect(function()
    local text = wlInput.Text
    currentSuggestion = ""
    wlSuggest.Text = ""
    if text == "" then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #text) == text:lower() then
            currentSuggestion = p.Name
            wlSuggest.Text = "→ " .. p.Name
            break
        end
    end
end)

-- Add to whitelist on Enter
wlInput.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local name = currentSuggestion ~= "" and currentSuggestion or wlInput.Text:match("^%s*(.-)%s*$")
        if name and name ~= "" then
            if whitelist[name] then
                whitelist[name] = nil
                notify("Removed lolol " .. name .. " from whitelist")
            else
                whitelist[name] = true
                notify("Added a nerd " .. name .. " to whitelist")
                sendChat(":h " .. name .. " has been whitelisted!!")
            end
            updateWlList()
        end
        wlInput.Text = ""
        wlSuggest.Text = ""
        currentSuggestion = ""
    end
end)

-- Drag Logic
local dragging, dragStart, startPos = false, nil, nil

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
        wlFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y + 118
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

