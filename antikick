-- Notification function
local function notify(msg)
    local screenGui2 = Instance.new("ScreenGui")
    screenGui2.ResetOnSpawn = false
    screenGui2.Parent = playerGui

    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(0, 250, 0, 40)
    notifFrame.Position = UDim2.new(0.5, -125, 0, 20)
    notifFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    notifFrame.BorderSizePixel = 0
    notifFrame.Parent = screenGui2

    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 8)
    notifCorner.Parent = notifFrame

    local notifLabel = Instance.new("TextLabel")
    notifLabel.Size = UDim2.new(1, 0, 1, 0)
    notifLabel.BackgroundTransparency = 1
    notifLabel.Text = msg
    notifLabel.TextColor3 = Color3.fromRGB(80, 200, 80)
    notifLabel.TextSize = 14
    notifLabel.Font = Enum.Font.GothamBold
    notifLabel.Parent = notifFrame

    task.delay(4, function()
        for i = 1, 10 do
            notifFrame.BackgroundTransparency = i / 10
            notifLabel.TextTransparency = i / 10
            task.wait(0.1)
        end
        screenGui2:Destroy()
    end)
end

-- Send chat function (legacy first)
local function sendChat(message)
    if not message or message == "" then return end

    task.wait(0.2)

    local ok1, err1 = pcall(function()
        local chatEvent = ReplicatedStorage:WaitForChild("DefaultChatSystemChatEvents", 3)
            :WaitForChild("SayMessageRequest", 3)
        chatEvent:FireServer(message, "All")
    end)

    if not ok1 then
        warn("Legacy chat failed: " .. tostring(err1))
        local ok2, err2 = pcall(function()
            local TextChatService = game:GetService("TextChatService")
            local channel = TextChatService.TextChannels:WaitForChild("RBXGeneral", 3)
            channel:SendAsync(message)
        end)
        if not ok2 then
            warn("TextChatService fallback also failed: " .. tostring(err2))
        end
    end
end

-- Detect gear
local function isGear(tool)
    local handle = tool:FindFirstChild("Handle")
    return handle and handle:FindFirstChildOfClass("SpecialMesh")
end

local function checkItem(item, ownerName)
    if item:IsA("Tool") and isGear(item) then
        if isEnabled then
            if ownerName and whitelist[ownerName] then return end
            local target = ownerName or "all"
            sendChat(":ungear " .. target)
            notify("⚙️ Gear detected on " .. (ownerName or "unknown") .. "!")
        end
    end
end

local function watchCharacter(character, ownerName)
    character.ChildAdded:Connect(function(item)
        checkItem(item, ownerName)
    end)
end

local function watchPlayer(p)
    if p.Character then
        watchCharacter(p.Character, p.Name)
    end
    p.CharacterAdded:Connect(function(char)
        watchCharacter(char, p.Name)
    end)
end

-- Watch all current and future players
Players.PlayerAdded:Connect(watchPlayer)
for _, p in ipairs(Players:GetPlayers()) do
    watchPlayer(p)
end

-- Also watch local backpack as fallback
player.CharacterAdded:Connect(function()
    task.wait(1)
    local backpack = player:WaitForChild("Backpack", 10)
    if backpack then
        backpack.ChildAdded:Connect(function(item)
            checkItem(item, player.Name)
        end)
    end
end)

