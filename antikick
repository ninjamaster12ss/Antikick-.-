-- Update whitelist display
local function updateWlList()
    local names = {}
    for name in pairs(whitelist) do
        table.insert(names, "• " .. name)
    end
    if #names == 0 then
        wlList.Text = "No players whitelisted"
    else
        wlList.Text = table.concat(names, "\n")
    end
end

-- Add to whitelist on Enter
wlInput.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local name = wlInput.Text:match("^%s*(.-)%s*$")
        if name and name ~= "" then
            if whitelist[name] then
                whitelist[name] = nil
                notify("Removed lolol " .. name .. " from whitelist")
            else
                whitelist[name] = true
                notify("Added a nerd " .. name .. " to whitelist")
            end
            updateWlList()
        end
        wlInput.Text = ""
    end
end)

-- Drag Logic
local dragging, dragStart, startPos = false, nil, nil

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
        wlFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y + 118
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

